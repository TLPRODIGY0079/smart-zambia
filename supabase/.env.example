# Supabase Environment Variables
# Copy this file to .env.local for local development
# For Vercel deployment, add these to Environment Variables

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (public, safe to expose)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (NEVER commit to git, use server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe Payment Integration
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Mobile Money Integration
MTN_MONEY_API_KEY=your_mtn_api_key
MTN_MONEY_SECRET=your_mtn_secret
AIRTEL_MONEY_API_KEY=your_airtel_api_key
AIRTEL_MONEY_SECRET=your_airtel_secret

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@smart-zambia.com

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Environment
NODE_ENV=development
